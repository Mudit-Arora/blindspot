# Blindspot Backend Environment Variables
# Copy this file to .env and fill in your API keys

# OpenAI API key — used for Whisper STT, GPT-4o reasoning, and fallback TTS
OPENAI_API_KEY=sk-your-openai-api-key-here

# Smallest.ai API key — used for Lightning TTS (optional, falls back to OpenAI TTS)
SMALLEST_AI_API_KEY=your-smallest-ai-api-key-here
