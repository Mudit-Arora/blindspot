# Blindspot Backend Environment Variables
# Copy this file to .env and fill in your API keys

# Smallest.ai API key — used for Pulse STT and Lightning v3.1 TTS
# Get one at https://smallest.ai
SMALLEST_AI_API_KEY=your-smallest-ai-api-key-here

# Groq API key — used for LLM reasoning (Llama 3.3 70B)
# Get one at https://console.groq.com
GROQ_API_KEY=your-groq-api-key-here
